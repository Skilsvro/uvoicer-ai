# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it's listed in .gitignore.

# Your Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-goes-here

# A random secret string used to secure user sessions.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-goes-here

# Optional: override where the database and files are stored.
# Set this to a Railway volume mount path for persistent storage (e.g. /data)
# DATA_DIR=/data
